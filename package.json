{
  "name": "express-file-routing",
  "version": "3.1.0",
  "description": "Simple file-based routing for Express",
  "author": "Matthias Halfmann",
  "repository": "matthiaaas/express-file-routing",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "scripts": {
    "test": "jest",
    "build": "npm run build:rollup",
    "build:rollup": "rollup -c",
    "build:tsc": "tsc && tsc --module commonjs --outDir dist/cjs",
    "postbuild": "node ./postbuild.mjs",
    "prepublish": "npm run build",
    "dev": "ts-node-dev --transpile-only --files --quiet ./examples/with-typescript/app.ts",
    "lint": "eslint . --ext .ts"
  },
  "exports": {
    "import": "./dist/esm/index.js",
    "require": "./dist/cjs/index.js"
  },
  "keywords": [
    "express",
    "api",
    "file",
    "router",
    "routing",
    "typescript"
  ],
  "license": "MIT",
  "peerDependencies": {
    "express": ">4.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "babel-core": "^6.26.3",
    "babel-runtime": "^6.26.0",
    "eslint": "^10.1.0",
    "express": "^5.2.1",
    "jest": "^30.3.0",
    "rollup": "^4.60.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "files": [
    "dist"
  ]
}
